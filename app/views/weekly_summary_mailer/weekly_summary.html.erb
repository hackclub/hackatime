<h1 class="text-2xl font-bold text-gray-900 tracking-tight mt-2 mb-0">
  Your coding recap
</h1>
<p class="text-sm text-gray-500 mt-1 mb-0">
  <%= @period_label %>
</p>
<p class="text-sm text-gray-600 mt-4 mb-0">
  Hi <strong><%= h(@user.display_name) %></strong>, here is your weekly coding snapshot from Hackatime.
</p>

<%= render "weekly_summary_mailer/hero_stats" %>

<% if @total_seconds.zero? %>
  <%= render "weekly_summary_mailer/empty_state" %>
<% else %>
  <%= render "weekly_summary_mailer/breakdown_table", title: "Top projects", items: @top_projects %>
  <%= render "weekly_summary_mailer/breakdown_table", title: "Top languages", items: @top_languages, spacing_class: "mt-4" %>
<% end %>

<div class="text-center">
  <%= render "shared/mailer/button", url: root_url, label: "View your dashboard →" %>
</div>
