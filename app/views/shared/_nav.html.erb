<%
  base_link = "block px-3 py-2 text-sm"
  active_class = "#{base_link} nav-link-active bg-primary text-on-primary font-bold"
  inactive_class = "#{base_link} text-surface-content hover:bg-darkless hover:text-primary"

  nav_link_class = ->(active) { active ? active_class : inactive_class }
%>
<aside class="flex min-h-screen w-52 flex-col overflow-y-auto rounded-r-2xl bg-dark px-3 py-4 text-surface-content shadow-[4px_0_24px_rgba(0,0,0,0.16),inset_-1px_0_0_rgba(255,255,255,0.06)] lg:block" data-nav-target="nav" style="scrollbar-width: none; -ms-overflow-style: none;">
  <div class="space-y-4">
    <% flash.each do |name, msg| %>
      <% next if name.to_sym == :application_secret %>
      <%
        c =
          case name.to_sym
          when :notice, :success
            'flash-message--success'
          else
            'flash-message--error'
          end
      %>
      <div class="flash-message flash-message--enter <%= c %>" data-controller="flash"><%= msg %></div>
    <% end %>

    <% if current_user %>
      <div class="flex flex-col items-center gap-2 rounded-xl px-2 pb-3 shadow-[0_1px_0_rgba(255,255,255,0.08)]"><%=
        render 'shared/user_mention', user: current_user
      %><% if current_user.streak_days_formatted.to_i > 0 %><%=
        render 'static_pages/streak', user: current_user, show_text: true, turbo_frame: false
      %><% end %><% if current_user.admin_level != 0 %><%=
        render 'static_pages/admin_level', user: current_user
      %><% end %></div>
    <% else %>
      <div>
        <%= link_to 'Sign in', signin_path, class: 'block px-4 py-2 rounded-md transition text-on-primary font-semibold bg-primary hover:bg-secondary text-center' %>
      </div>
    <% end %>

    <nav class="space-y-1">
      <%= link_to 'Home', root_path, class: nav_link_class.call(current_page?(root_path)), data: { action: "click->nav#clickLink" } %>

      <%= link_to 'Leaderboards', leaderboards_path, class: nav_link_class.call(current_page?(leaderboards_path)), data: { action: "click->nav#clickLink" } %>

      <% unless current_user %>
        <%= link_to 'Docs', docs_path, class: nav_link_class.call(current_page?(docs_path) || request.path.start_with?('/docs')), data: { action: "click->nav#clickLink" } %>

        <%= link_to 'Extensions', extensions_path, class: nav_link_class.call(current_page?(extensions_path)), data: { action: "click->nav#clickLink" } %>
      <% end %>

      <% if current_user %>
        <%= link_to 'Projects', my_projects_path, class: nav_link_class.call(current_page?(my_projects_path)), data: { action: "click->nav#clickLink" } %>

        <%= link_to 'Docs', docs_path, class: nav_link_class.call(current_page?(docs_path) || request.path.start_with?('/docs')), data: { action: "click->nav#clickLink" } %>

        <%= link_to 'Extensions', extensions_path, class: nav_link_class.call(current_page?(extensions_path)), data: { action: "click->nav#clickLink" } %>

        <%= link_to 'Settings', my_settings_path, class: nav_link_class.call(current_page?(my_settings_path)), data: { action: "click->nav#clickLink" } %>

        <%= link_to 'My OAuth Apps', oauth_applications_path, class: nav_link_class.call(current_page?(oauth_applications_path) || request.path.start_with?('/oauth/applications')), data: { action: "click->nav#clickLink" } %>

        <a type="button" onclick="showLogout()" class="<%= inactive_class %> w-full text-left cursor-pointer">Logout</a>
      <% end %>

      <% if current_user&.admin_level.present? || Rails.env.development? %>
        <div class="pt-2 mt-2 space-y-1 shadow-[0_-1px_0_rgba(255,255,255,0.08)]">
          <% dev_tool(nil, "div") do %>
            <%= link_to 'Letter Opener', letter_opener_web_path, class: nav_link_class.call(current_page?(letter_opener_web_path)), data: { action: "click->nav#clickLink" } %>
          <% end %>

          <% dev_tool(nil, "div") do %>
            <%= link_to 'Mailers', '/rails/mailers', class: nav_link_class.call(current_page?('/rails/mailers')), data: { action: "click->nav#clickLink" } %>
          <% end %>

          <% if current_user&.admin_level == "admin" || current_user&.admin_level == "superadmin" || current_user&.admin_level == "ultraadmin" %>
            <% admin_tool(nil, "div") do %>
              <%= link_to 'Review Timeline', admin_timeline_path, class: nav_link_class.call(current_page?(admin_timeline_path)), data: { action: "click->nav#clickLink" } %>
            <% end %>
          <% elsif current_user&.admin_level == "viewer" %>
            <% viewer_tool(nil, "div") do %>
              <%= link_to 'Review Timeline', admin_timeline_path, class: nav_link_class.call(current_page?(admin_timeline_path)), data: { action: "click->nav#clickLink" } %>
            <% end %>
          <% end %>

          <% if current_user&.admin_level == "admin" || current_user&.admin_level == "superadmin" || current_user&.admin_level == "ultraadmin" %>
            <% admin_tool(nil, "div") do %>
              <%= link_to 'Trust Level Logs', admin_trust_level_audit_logs_path, class: nav_link_class.call(current_page?(admin_trust_level_audit_logs_path) || request.path.start_with?('/admin/trust_level_audit_logs')), data: { action: "click->nav#clickLink" } %>
            <% end %>
          <% elsif current_user&.admin_level == "viewer" %>
            <% viewer_tool(nil, "div") do %>
              <%= link_to 'Trust Level Logs', admin_trust_level_audit_logs_path, class: nav_link_class.call(current_page?(admin_trust_level_audit_logs_path) || request.path.start_with?('/admin/trust_level_audit_logs')), data: { action: "click->nav#clickLink" } %>
            <% end %>
          <% end %>

          <% if current_user&.admin_level == "admin" || current_user&.admin_level == "superadmin" || current_user&.admin_level == "ultraadmin" %>
            <% admin_tool(nil, "div") do %>
              <%= link_to 'Admin API Keys', admin_admin_api_keys_path, class: nav_link_class.call(current_page?(admin_admin_api_keys_path) || request.path.start_with?('/admin/admin_api_keys')), data: { action: "click->nav#clickLink" } %>
            <% end %>
          <% elsif current_user&.admin_level == "viewer" %>
            <% viewer_tool(nil, "div") do %>
              <%= link_to 'Admin API Keys', admin_admin_api_keys_path, class: nav_link_class.call(current_page?(admin_admin_api_keys_path) || request.path.start_with?('/admin/admin_api_keys')), data: { action: "click->nav#clickLink" } %>
            <% end %>
          <% end %>

          <% superadmin_tool(nil, "div") do %>
            <%= link_to 'Admin Management', admin_admin_users_path, class: nav_link_class.call(current_page?(admin_admin_users_path)), data: { action: "click->nav#clickLink" } %>
          <% end %>

          <% superadmin_tool(nil, "div") do %>
            <%= link_to admin_deletion_requests_path, class: nav_link_class.call(current_page?(admin_deletion_requests_path)), data: { action: "click->nav#clickLink" } do %>
              Account Deletions
              <% pending_count = DeletionRequest.pending.count %>
              <% if pending_count > 0 %>
                <span class="ml-1 px-1.5 py-0.5 text-xs rounded-full bg-primary text-on-primary font-medium tabular-nums"><%= pending_count %></span>
              <% end %>
            <% end %>
          <% end %>

          <% superadmin_tool(nil, "div") do %>
            <%= link_to 'All OAuth Apps', admin_oauth_applications_path, class: nav_link_class.call(current_page?(admin_oauth_applications_path) || request.path.start_with?('/admin/oauth_applications')), data: { action: "click->nav#clickLink" } %>
          <% end %>

          <% ultraadmin_tool(nil, "div") do %>
            <%= link_to 'GoodBoy', good_job_path, class: nav_link_class.call(current_page?(good_job_path)), data: { action: "click->nav#clickLink" } %>
          <% end %>

          <% ultraadmin_tool(nil, "div") do %>
            <%= link_to 'Feature Flags', flipper_path, class: nav_link_class.call(current_page?(flipper_path)), data: { action: "click->nav#clickLink" } %>
          <% end %>

          <% ultraadmin_tool(nil, "div") do %>
            <%= link_to 'Account Merger', admin_account_merger_path, class: nav_link_class.call(current_page?(admin_account_merger_path) || request.path.start_with?('/admin/account_merger')), data: { action: "click->nav#clickLink" } %>
          <% end %>
        </div>
      <% end %>
    </nav>
  </div>
</aside>
